# Password untuk masuk ke halaman /admin (ganti dengan password yang kuat)
ADMIN_PASSWORD=ganti-ini

# GitHub Personal Access Token (scope: repo) - dipakai admin panel untuk
# publish artikel baru langsung ke repo, yang otomatis men-trigger deploy di Vercel
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=username-atau-organisasi-github-kamu
GITHUB_REPO=nama-repo-ini
GITHUB_BRANCH=main
